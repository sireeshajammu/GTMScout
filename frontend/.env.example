# Copy to .env.local (local dev) or set in Vercel project settings (production).

# URL of the GTMScout backend. Leave EMPTY to run the UI on mock data.
# Local dev example:   http://localhost:8000
# Production example:  https://gtmscout-api.vercel.app
VITE_API_BASE=

# Optional override of mock mode:
#   "true"  -> always use built-in mock data (no backend needed)
#   "false" -> always call the real backend (VITE_API_BASE must be set)
#   unset   -> automatic: mocks when VITE_API_BASE is empty, real otherwise
# VITE_USE_MOCKS=
