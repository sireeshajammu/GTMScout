# Copy to .env and fill in. NEVER commit the real .env.
OPENAI_API_KEY=sk-...your-key...

# Live web research (Tavily). Get a free key at https://tavily.com (free tier ~1,000/mo).
# Without it, the app still works but skips live web intel that turn.
TAVILY_API_KEY=tvly-...your-key...

# RAG research cache (optional). A Postgres URL with the pgvector extension
# (Supabase or Neon free tier). Without it, the app skips the cache and still works.
# Use the POOLED connection string on serverless. Example:
# DATABASE_URL=postgresql://user:pass@host:6543/postgres
DATABASE_URL=

# Optional: restrict CORS to your deployed frontend origin(s), comma-separated.
# Example: https://gtmscout.vercel.app
FRONTEND_ORIGIN=*
