# Copy to .env and fill in. NEVER commit the real .env.
OPENAI_API_KEY=sk-...your-key...

# Live web research (Tavily). Get a free key at https://tavily.com (free tier ~1,000/mo).
# Without it, the app still works but skips live web intel that turn.
TAVILY_API_KEY=tvly-...your-key...

# Optional: restrict CORS to your deployed frontend origin(s), comma-separated.
# Example: https://gtmscout.vercel.app
FRONTEND_ORIGIN=*
